# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=NetSupportAI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING

# ─── Auth tokens ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://netsupport:strongpassword@db:5432/netsupportai

# ─── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ─── AI auto-triage threshold ──────────────────────────────────────────────────
# Tickets with AI confidence >= this value are auto-resolved (0.0–1.0)
AI_AUTO_RESOLVE_CONFIDENCE=0.85

# ─── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=["https://your-domain.com","http://localhost:5173"]

# ─── SMTP / Email ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.fastmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@netsupportai.com
SMTP_TLS=true

# ─── Twilio (WhatsApp) ─────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_DEFAULT_CHAT_ID=-100123456789

# ─── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/var/log/netsupportai
LOG_RETENTION_DAYS=30

# ─── Monitoring ────────────────────────────────────────────────────────────────
MONITOR_INTERVAL_SECONDS=60
PING_TIMEOUT_SECONDS=5.0
SNMP_DEFAULT_COMMUNITY=public
SNMP_PORT=161
SNMP_TIMEOUT=5

# ─── SSH ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SSH_ENCRYPTION_KEY=GENERATE_A_FERNET_KEY_AND_PASTE_HERE
SSH_KEY_PATH=/home/netsupportai/.ssh/id_rsa
SSH_TIMEOUT=30

# ─── SLA hours by ticket priority ──────────────────────────────────────────────
SLA_CRITICAL_HOURS=1
SLA_HIGH_HOURS=4
SLA_MEDIUM_HOURS=8
SLA_LOW_HOURS=24

# ─── Ticket Numbering ──────────────────────────────────────────────────────────
TICKET_PREFIX=NSA
